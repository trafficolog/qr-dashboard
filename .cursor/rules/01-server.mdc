# Server Code Rules

## Паттерн API-хэндлера

```typescript
import { z } from 'zod'
import { entityService } from '../../services/entity.service'

const schema = z.object({ /* ... */ })

export default defineEventHandler(async (event) => {
  const user = requireAuth(event)                              // 1. Auth
  const body = await readValidatedBody(event, schema.parse)    // 2. Validate
  const result = await entityService.method(body, user)        // 3. Service
  return apiSuccess(result)                                     // 4. Response
})
```

Для GET: `getValidatedQuery(event, schema.parse)` вместо `readValidatedBody`.

## Паттерн сервиса

```typescript
import { db } from '../db'
import { table } from '../db/schema'
import { eq, and } from 'drizzle-orm'

export const entityService = {
  async list(filters, user: User) {
    // Role-based access
    if (user.role !== 'admin') {
      conditions.push(eq(table.createdBy, user.id))
    }
    // Drizzle relational queries
    const data = await db.query.table.findMany({ where, with: {...}, limit, offset })
    return { data, total, page, limit, totalPages }
  },
}
```


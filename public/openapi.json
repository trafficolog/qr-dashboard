{
  "openapi": "3.1.0",
  "info": {
    "title": "SPLAT QR Dashboard API",
    "version": "1.0.0",
    "description": "Internal and public API surface for QR Dashboard."
  },
  "servers": [
    {
      "url": "/"
    }
  ],
  "security": [
    {
      "ApiKeyAuth": []
    }
  ],
  "components": {
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "sqr_live_<64_hex>",
        "description": "API key via Authorization: Bearer sqr_live_<64_hex>"
      }
    },
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "enum": [
              false
            ]
          },
          "error": {
            "type": "object",
            "properties": {
              "code": {
                "type": "string"
              },
              "message": {
                "type": "string"
              },
              "details": {
                "type": "object",
                "additionalProperties": {}
              }
            },
            "required": [
              "code",
              "message"
            ]
          }
        },
        "required": [
          "success",
          "error"
        ]
      },
      "PaginationMeta": {
        "type": "object",
        "properties": {
          "total": {
            "type": "integer",
            "minimum": 0
          },
          "page": {
            "type": "integer",
            "exclusiveMinimum": 0
          },
          "limit": {
            "type": "integer",
            "exclusiveMinimum": 0
          },
          "totalPages": {
            "type": "integer",
            "minimum": 0
          }
        },
        "required": [
          "total",
          "page",
          "limit",
          "totalPages"
        ]
      },
      "QrStatus": {
        "type": "string",
        "enum": [
          "active",
          "paused",
          "expired",
          "archived"
        ]
      },
      "QrVisibility": {
        "type": "string",
        "enum": [
          "private",
          "department",
          "public"
        ]
      },
      "QrItem": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "title": {
            "type": "string"
          },
          "shortCode": {
            "type": "string"
          },
          "status": {
            "$ref": "#/components/schemas/QrStatus"
          },
          "visibility": {
            "$ref": "#/components/schemas/QrVisibility"
          },
          "totalScans": {
            "type": "integer",
            "minimum": 0
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          }
        },
        "required": [
          "id",
          "title",
          "shortCode",
          "status",
          "visibility",
          "totalScans",
          "createdAt",
          "updatedAt"
        ]
      },
      "QrListResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "enum": [
              true
            ]
          },
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/QrItem"
            }
          },
          "meta": {
            "$ref": "#/components/schemas/PaginationMeta"
          }
        },
        "required": [
          "success",
          "data",
          "meta"
        ]
      },
      "AnalyticsOverviewItem": {
        "type": "object",
        "properties": {
          "date": {
            "type": "string"
          },
          "scans": {
            "type": "integer",
            "minimum": 0
          },
          "uniqueScans": {
            "type": "integer",
            "minimum": 0
          }
        },
        "required": [
          "date",
          "scans",
          "uniqueScans"
        ]
      },
      "AnalyticsOverviewResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "enum": [
              true
            ]
          },
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/AnalyticsOverviewItem"
            }
          }
        },
        "required": [
          "success",
          "data"
        ]
      }
    },
    "parameters": {}
  },
  "paths": {
    "/api/qr": {
      "get": {
        "tags": [
          "QR"
        ],
        "security": [
          {
            "ApiKeyAuth": [
              "qr:read"
            ]
          }
        ],
        "parameters": [
          {
            "schema": {
              "type": "integer",
              "minimum": 1,
              "default": 1
            },
            "required": false,
            "name": "page",
            "in": "query"
          },
          {
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 100,
              "default": 20
            },
            "required": false,
            "name": "limit",
            "in": "query"
          },
          {
            "schema": {
              "type": "string",
              "enum": [
                "createdAt",
                "title",
                "totalScans"
              ],
              "default": "createdAt"
            },
            "required": false,
            "name": "sortBy",
            "in": "query"
          },
          {
            "schema": {
              "type": "string",
              "enum": [
                "asc",
                "desc"
              ],
              "default": "desc"
            },
            "required": false,
            "name": "sortOrder",
            "in": "query"
          },
          {
            "schema": {
              "type": "string"
            },
            "required": false,
            "name": "search",
            "in": "query"
          },
          {
            "schema": {
              "$ref": "#/components/schemas/QrStatus"
            },
            "required": false,
            "name": "status",
            "in": "query"
          },
          {
            "schema": {
              "$ref": "#/components/schemas/QrVisibility"
            },
            "required": false,
            "name": "visibility",
            "in": "query"
          }
        ],
        "responses": {
          "200": {
            "description": "Paginated list of QR codes",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/QrListResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/analytics/overview": {
      "get": {
        "tags": [
          "Analytics"
        ],
        "security": [
          {
            "ApiKeyAuth": [
              "qr:stats:read"
            ]
          }
        ],
        "parameters": [
          {
            "schema": {
              "type": "string",
              "enum": [
                "7d",
                "30d",
                "90d",
                "1y"
              ],
              "default": "30d"
            },
            "required": false,
            "name": "range",
            "in": "query"
          },
          {
            "schema": {
              "type": "string",
              "format": "uuid"
            },
            "required": false,
            "name": "qrId",
            "in": "query"
          }
        ],
        "responses": {
          "200": {
            "description": "Analytics overview timeseries",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AnalyticsOverviewResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "webhooks": {}
}
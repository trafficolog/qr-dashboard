{
  "name": "splat-qr",
  "version": "0.13.0",
  "private": true,
  "description": "SPLAT Global — QR Dashboard",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:seed": "npx tsx server/db/seed.ts",
    "typecheck": "nuxt typecheck",
    "test:e2e": "playwright test",
    "test:unit": "vitest run",
    "openapi:generate": "tsx server/openapi/generate.ts",
    "openapi:validate": "node -e \"JSON.parse(require('fs').readFileSync('public/openapi.json','utf8')); console.log('openapi.json is valid JSON')\"",
    "sdks:generate": "bash scripts/generate-sdks.sh"
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^7.3.4",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@pinia/nuxt": "^0.9.0",
    "@scalar/api-reference": "^1.52.3",
    "@sentry/node": "^8.0.0",
    "@vueuse/nuxt": "^12.0.0",
    "dotenv": "^16.4.0",
    "drizzle-orm": "^0.38.0",
    "echarts": "^5.5.0",
    "geoip-lite": "^1.4.0",
    "lru-cache": "^11.0.0",
    "nanoid": "^5.0.0",
    "node-cron": "^3.0.0",
    "nodemailer": "^6.9.0",
    "nuxt": "^3.16.0",
    "papaparse": "^5.4.0",
    "pdfkit": "^0.16.0",
    "pg": "^8.13.0",
    "pinia": "^2.3.0",
    "qrcode": "^1.5.0",
    "sharp": "^0.33.0",
    "ua-parser-js": "^1.0.0",
    "vue": "^3.5.0",
    "vue-echarts": "^7.0.0",
    "vue-router": "^4.5.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.2",
    "@nuxt/eslint-config": "^0.7.0",
    "@nuxt/icon": "^1.10.0",
    "@nuxt/ui": "^3.0.0",
    "@nuxtjs/i18n": "^9.0.0",
    "@playwright/test": "^1.48.0",
    "@tailwindcss/postcss": "^4.2.2",
    "@tailwindcss/vite": "^4.2.2",
    "@types/geoip-lite": "^1.4.0",
    "@types/node-cron": "^3.0.0",
    "@types/nodemailer": "^6.4.0",
    "@types/papaparse": "^5.5.2",
    "@types/pdfkit": "^0.13.0",
    "@types/pg": "^8.11.0",
    "@types/qrcode": "^1.5.0",
    "@types/ua-parser-js": "^0.7.0",
    "drizzle-kit": "^0.30.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.4.0",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.8"
  },
  "packageManager": "pnpm@10.17.1"
}

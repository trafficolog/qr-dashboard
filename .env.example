# App
NUXT_PUBLIC_APP_URL=http://localhost:3000
NUXT_PUBLIC_APP_NAME=SPLAT QR Service

# Database
DATABASE_URL=postgresql://splat_qr:secret@localhost:5432/splat_qr

# Auth
OTP_TTL_MINUTES=10
OTP_MAX_ATTEMPTS=5
SESSION_TTL_DAYS=30
CSRF_SECRET=
OTP_PEPPER=
NUXT_PUBLIC_CSRF_HEADER_NAME=X-CSRF-Token

# Email (SMTP)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=qr-service@splat.com
SMTP_PASSWORD=
SMTP_FROM="SPLAT QR Service <qr-service@splat.com>"

# Или Resend
RESEND_API_KEY=

# GeoIP
MAXMIND_LICENSE_KEY=
MAXMIND_DB_PATH=./data/GeoLite2-City.mmdb

# Storage
STORAGE_DRIVER=local
STORAGE_LOCAL_PATH=./data/uploads

# Optional
SENTRY_DSN=
